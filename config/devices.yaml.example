devices:
  - name: 客厅灯
    model: yeelink.light.lamp1
    host: 192.168.1.100
    token: <32位hex token>
    type: light
  - name: 卧室空调
    model: zhimi.aircondition.v1
    host: 192.168.1.101
    token: <32位hex token>
    type: airconditioner
    # 仅在确认当前 model 的 miio 命令后声明温控能力；未知设备不要照抄。
    temperature:
      min: 16
      max: 30
      step: 1
      command: set_temperature
      # 若该 model 支持 get_prop 查询目标温度，可取消下一行注释：
      # property: target_temperature
  - name: 客厅插座
    model: chuangmi.plug.m1
    host: 192.168.1.102
    token: <32位hex token>
    type: plug
