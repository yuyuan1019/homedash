# ========== 当前部署（已支持）==========

# Uptime Kuma 的 SQLite 文件路径（容器内路径）
KUMA_DB_PATH=/kuma-data/kuma.db

# 米家设备配置文件路径
DEVICES_PATH=/app/config/devices.yaml

# 宿主机上 Uptime Kuma 数据目录；目录内应有 kuma.db。不填则使用 ./data
KUMA_DATA_DIR=./data

# HomeDash 对外端口
HOMEDASH_PORT=8088

# 小米账号（可选，仅首次获取云端凭据；成功后可用 data/xiaomi_cloud.json）
# XIAOMI_USERNAME=
# XIAOMI_PASSWORD=

# ========== 规划中：SMTP 周报（DEVPLAN 待办 6，实现前可忽略）==========
# QQ 邮箱示例：在网页邮箱设置中开启 SMTP 后生成授权码；禁止提交真实授权码。
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-qq-number@qq.com
SMTP_PASSWORD=
SMTP_FROM="HomeDash <your-qq-number@qq.com>"
# 两位收件人用英文逗号分隔。
NOTIFY_TO=person-a@example.com,person-b@example.com
NOTIFY_ENABLED=false
NOTIFY_CRON="0 18 * * 0"
NOTIFY_TZ=Asia/Shanghai
NOTIFY_ONLY_WHEN_NEED_BUY=false
NOTIFY_TODO_LIMIT=20
HOMEDASH_PUBLIC_URL=http://127.0.0.1:8088

# ========== AI 工作台（OpenAI-compatible）==========
# LLM_BASE_URL=https://your-openai-compatible/v1
# LLM_API_KEY=
# LLM_MODEL=
# LLM_TIMEOUT_SEC=30
# AI_ENABLED=true
# AI_CONFIRM_REQUIRED=true
# AI_MAX_ACTIONS=8

# ========== home agent 接口（重点待办）==========
# 留空仅适合家庭内网；映射公网端口时必须设置强随机 token。
AGENT_API_TOKEN=
