# ========== 当前部署（已支持）==========

# Uptime Kuma 的 SQLite 文件路径（容器内路径）
KUMA_DB_PATH=/kuma-data/kuma.db

# 米家设备配置文件路径
DEVICES_PATH=/app/config/devices.yaml

# 宿主机上 Uptime Kuma 数据目录；目录内应有 kuma.db。不填则使用 ./data
KUMA_DATA_DIR=./data

# HomeDash 对外端口
HOMEDASH_PORT=8088

# 小米账号（可选，仅首次获取云端凭据；成功后可用 data/xiaomi_cloud.json）
# XIAOMI_USERNAME=
# XIAOMI_PASSWORD=

# ========== 规划中：Gmail 周报（DEVPLAN 待办 6，实现前可忽略）==========
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=HomeDash <you@gmail.com>
# NOTIFY_TO=you@gmail.com
# NOTIFY_ENABLED=false
# NOTIFY_CRON=0 18 * * 0
# NOTIFY_TZ=Asia/Shanghai
# NOTIFY_ONLY_WHEN_NEED_BUY=false
# NOTIFY_TODO_LIMIT=20
# HOMEDASH_PUBLIC_URL=http://127.0.0.1:8088

# ========== 规划中：AI 工作台（DEVPLAN 待办 7，实现前可忽略）==========
# LLM_BASE_URL=https://your-openai-compatible/v1
# LLM_API_KEY=
# LLM_MODEL=
# LLM_TIMEOUT_SEC=30
# AI_ENABLED=true
# AI_CONFIRM_REQUIRED=true
# AI_MAX_ACTIONS=8

# ========== 规划中：home agent 接口（DEVPLAN 待办 8，实现前可忽略）==========
# AGENT_API_TOKEN=
